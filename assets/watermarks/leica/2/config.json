{
  "version": 1.0,
  "metadata": {
    "name": "@wm_leica_2_name",
    "id": "2",
    "description": "leica_2",
    "reminder_not_support_mode": ["front", "multi", "raw", "200m", "doc", "pano", "mimoji", "instant"],
    "show_in_menu": true,
    "limitation": {
      "system_properties": {
        "ro.product.device": ["xuanyuan"]
      },
      "device_type": ["leica"]
    },
    "priority": 2,
    "exclude_cases": ["front", "multi", "cosmetic", "doc", "pano", "mimoji", "200m"]
  },
  "layout_group": [
    {
      "layout": [
        {
          "type": "Layout",
          "id": "all_content",
          "orientation": "horizontal",
          "layout_width": "wrap_content",
          "layout_height": "wrap_content",
          "gravity": "center",
          "margin_left": "0dp",
          "margin_top": "0dp",
          "background": "@background=white",
          "background_optional": true,
          "childViews": [
            {
              "type": "Layout",
              "id": "left_padding",
              "orientation": "horizontal",
              "layout_width": "80dp",
              "layout_height": "match_parent",
              "gravity": "left",
              "margin_left": "0dp",
              "margin_top": "0dp",
              "childViews": []
            },
            {
              "type": "Layout",
              "id": "content_layout",
              "orientation": "vertical",
              "layout_width": "wrap_content",
              "layout_height": "wrap_content",
              "gravity": "center",
              "margin_left": "0dp",
              "margin_top": "0dp",
              "childViews": [
                {
                  "type": "Layout",
                  "id": "top_content_layout",
                  "orientation": "none",
                  "layout_width": "match_parent",
                  "layout_height": "80dp",
                  "gravity": "left",
                  "margin_left": "0dp",
                  "margin_top": "0dp",
                  "childViews": [
                    {
                      "type": "Layout",
                      "id": "brand_layout",
                      "orientation": "horizontal",
                      "layout_width": "wrap_content",
                      "layout_height": "wrap_content",
                      "gravity": "right|bottom",
                      "margin_left": "0dp",
                      "margin_top": "-7dp",
                      "setting_optional_type": "type_model",
                      "childViews": [
                        {
                          "type": "ImageView",
                          "id": "logo",
                          "layout_gravity": "center_vertical",
                          "margin_left": "0dp",
                          "margin_top": "0dp",
                          "display_height": "24dp",
                          "display_width": "0dp",
                          "path": "pathType=fill;path=${logo};foreground=3"
                        },
                        {
                          "type": "TextView",
                          "id": "model",
                          "margin_left": "0dp",
                          "layout_gravity": "center_vertical",
                          "text": "@model= @{series}@{versionNumber}@{versionName}",
                          "font_ref": "f1"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "ImageView",
                  "id": "src_image_view",
                  "layout_gravity": "left",
                  "margin_left": "0dp",
                  "margin_top": "0dp",
                  "display_height": "0dp",
                  "path": ""
                },
                {
                  "type": "Layout",
                  "id": "bottom_content_layout",
                  "orientation": "none",
                  "layout_width": "match_parent",
                  "layout_height": "250dp",
                  "gravity": "center",
                  "margin_left": "0dp",
                  "margin_top": "0dp",
                  "childViews": [
                    {
                      "type": "Layout",
                      "id": "leica_exif_location_time",
                      "orientation": "vertical",
                      "layout_width": "wrap_content",
                      "layout_height": "wrap_content",
                      "gravity": "center",
                      "margin_left": "0dp",
                      "margin_top": "0dp",
                      "childViews":[
                        {
                          "type": "ImageView",
                          "id": "leica",
                          "layout_gravity": "center_horizontal",
                          "margin_left": "0dp",
                          "margin_top": "0dp",
                          "display_height": "72dp",
                          "display_width": "0dp",
                          "path": "pathType=direct;path=leica.webp",
                          "path_mivi": "pathType=direct;path=leica_p3.webp"
                        },
                        {
                          "type": "TextView",
                          "id": "exif",
                          "margin_top": "20dp",
                          "layout_gravity": "center_horizontal",
                          "text": "@exif=@{focal}mm  f/@{aperture}  @{speed}s  ISO@{iso}",
                          "font_ref": "f2"
                        },
                        {
                          "type": "TextView",
                          "id": "location",
                          "optional": true,
                          "margin_top": "12dp",
                          "layout_gravity": "center_horizontal",
                          "text": "@location=location_latlng_switch;@locationLimit=0.8",
                          "font_ref": "f3"
                        },
                        {
                          "type": "TextView",
                          "id": "time",
                          "optional": true,
                          "layout_gravity": "center_horizontal",
                          "margin_left": "0dp",
                          "margin_top": "12dp",
                          "text": "@time=@wm_time_yyyy_MM_dd_HH_mm",
                          "font_ref": "f3"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "Layout",
                  "id": "bottom_padding",
                  "orientation": "horizontal",
                  "layout_width": "match_parent",
                  "layout_height": "8dp",
                  "gravity": "left",
                  "margin_left": "0dp",
                  "margin_top": "0dp",
                  "childViews": []
                }
              ]
            },
            {
              "type": "Layout",
              "id": "right_padding",
              "orientation": "horizontal",
              "layout_width": "80dp",
              "layout_height": "match_parent",
              "gravity": "left",
              "margin_left": "0dp",
              "margin_top": "0dp",
              "childViews": []
            }
          ]
        }
      ]
    }
  ],
  "wmRes": {
    "background": [
      {
        "name": "white",
        "icon": "@img=icon_background_white.webp",
        "value": "@color=#FFFFFFFF",
        "foreground": ["#FF000000", "#4D000000", "#80000000", "black"]
      },
      {
        "name": "black",
        "icon": "@img=icon_background_black.webp",
        "value": "@color=#FF141414",
        "foreground": ["#FFFFFFFF", "#B2FFFFFF", "#80FFFFFF", "white"]
      }
    ],
    "fonts": {
      "f1": {
        "size": 21.6,
        "color": "@foreground=0",
        "typeface": "default",
        "variation": "'wght' 501"
      },
      "f2": {
        "size": 20.0,
        "color": "#FFE20612",
        "typeface": "oxanium",
        "variation": "'wght' 451",
        "letterSpacing": 0.15
      },
      "f3": {
        "size": 20.0,
        "color": "@foreground=2",
        "typeface": "oxanium",
        "variation": "'wght' 451",
        "letterSpacing": 0.15
      }
    }
  }
}