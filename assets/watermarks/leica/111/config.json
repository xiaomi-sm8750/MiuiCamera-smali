                    {
                      "type": "ImageView",
                      "id": "leica",
                      "layout_gravity": "center_horizontal",
                      "margin_left": "0dp",
                      "margin_top": "50dp",
                      "display_height": "74dp",
                      "display_width": "0dp",
                      "path": "pathType=direct;path=leica.webp",
                      "path_mivi": "pathType=direct;path=leica_p3.webp"
                    },
                    {
                      "type": "Layout",
                      "id": "brand_layout",
                      "orientation": "horizontal",
                      "layout_width": "wrap_content",
                      "layout_height": "wrap_content",
