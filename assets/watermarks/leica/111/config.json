                      "margin_left": "0dp",
                      "margin_top": "157.5dp",
                      "childViews": [
                        {
                          "type": "ImageView",
                          "id": "logo",
                          "layout_gravity": "center_vertical",
                          "margin_left": "0dp",
                          "margin_top": "0dp",
                          "display_height": "28dp",
                          "display_width": "0dp",
                          "path": "pathType=fill;path=${logo};foreground=2"
                        },
                        {
                          "type": "TextView",
                          "id": "model",
                          "margin_left": "0dp",
                          "layout_gravity": "center_vertical",
                          "text": "@model= @{series}@{versionNumber}@{versionName}",
                          "text_upper": false,
                          "font_ref": "f1"
                        }
                      ]
                    },
                    {
                      "type": "TextView",
                      "id": "exif",
                      "margin_top": "197dp",
