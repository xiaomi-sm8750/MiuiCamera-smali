                      "margin_left": "0dp",
                      "margin_top": "0dp",
                      "optional": true,
                      "setting_optional_type": "type_time",
                      "childViews": [
                        {
                          "type": "TextView",
                          "id": "time",
                          "layout_gravity": "right|center_vertical",
                          "margin_left": "0dp",
                          "margin_top": "0dp",
                          "text": "@time=@wm_time_yyyy_MM_dd_HH_mm",
