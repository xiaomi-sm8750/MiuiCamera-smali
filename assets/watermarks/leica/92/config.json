                          "margin_left": "0dp",
                          "margin_top": "0dp",
                          "childViews": [
                            {
                              "type": "TextView",
                              "id": "exif_mm",
                              "margin_top": "0dp",
                              "layout_gravity": "left|center_vertical",
                              "text": "@exif=@{focal}mm",
                              "font_ref": "f3"
