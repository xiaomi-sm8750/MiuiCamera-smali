                              "layout_width": "wrap_content",
                              "layout_height": "wrap_content",
                              "gravity": "left|center_vertical",
                              "margin_left": "0dp",
                              "margin_top": "0dp",
                              "childViews": [
                                {
                                  "type": "TextView",
                                  "id": "F",
                                  "margin_left": "0dp",
                                  "layout_gravity": "center_vertical",
                                  "text": "F",
                                  "text_upper": true,
                                  "font_ref": "f4"
                                },
                                {
                                  "type": "TextView",
                                  "id": "exif_f",
                                  "margin_left": "8dp",
                                  "layout_gravity": "center_vertical",
                                  "text": "@exif=@{aperture}",
                                  "font_ref": "f3"
                                },
                                {
                                  "type": "TextView",
                                  "id": "S",
                                  "margin_left": "20dp",
                                  "layout_gravity": "center_vertical",
                                  "text": "S",
                                  "text_upper": true,
                                  "font_ref": "f4"
                                },
                                {
                                  "type": "TextView",
                                  "id": "exif_s",
                                  "margin_left": "8dp",
                                  "layout_gravity": "center_vertical",
                                  "text": "@exif=@{speed}",
                                  "font_ref": "f3"
                                },
                                {
                                  "type": "TextView",
                                  "id": "ISO",
                                  "margin_left": "20dp",
                                  "layout_gravity": "center_vertical",
                                  "text": "ISO",
                                  "text_upper": true,
                                  "font_ref": "f4"
                                },
                                {
                                  "type": "TextView",
                                  "id": "exif_iso",
                                  "margin_left": "8dp",
                                  "layout_gravity": "center_vertical",
                                  "text": "@exif=@{iso}",
                                  "font_ref": "f3"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "Layout",
                  "id": "right_bottom_group",
                  "orientation": "vertical",
                  "layout_width": "wrap_content",
                  "layout_height": "wrap_content",
                  "gravity": "right|center_vertical",
                  "margin_left": "-80dp",
                  "margin_top": "0dp",
                  "childViews": [
                    {
                      "type": "Layout",
                      "id": "location_layout",
                      "orientation": "none",
                      "layout_width": "50%w",
                      "layout_height": "16dp",
                      "gravity": "right",
                      "optional": true,

                      "setting_optional_type": "type_location",
                      "childViews": [
                        {
                          "type": "TextView",
                          "id": "location",
                          "layout_gravity": "right|center_vertical",

                          "text": "@location=location_latlng_switch;@locationLimit=0.8",
                          "font_ref": "f4"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "wmRes": {
